# Supabase (for auth, forum, content submissions)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq (for AI agents, moderation, content generation)
GROQ_API_KEY=gsk_your-groq-key-here

# YouTube Data API v3 (for ريم YouTube scout — free: 10,000 units/day)
YOUTUBE_API_KEY=your-youtube-api-key-here

# Resend (for email notifications — free: 100 emails/day)
RESEND_API_KEY=re_your-resend-key-here

# Owner email (CEO sends daily reports here)
OWNER_EMAIL=your-email@example.com
