---
const platformLinks = [
  { href: '#bible', label: 'الموسوعة' },
  { href: '#articles', label: 'المقالات' },
  { href: '#enhancer', label: 'مُحسّن البرومبت' },
  { href: '#tools', label: 'الأدوات' },
];

const learnLinks = [
  { href: '#tips', label: 'نصائح وحيل' },
  { href: '#prompts', label: 'برومبتات مقترحة' },
  { href: '#source', label: 'الكود المصدري' },
  { href: '#forum', label: 'المنتدى' },
];

const connectLinks = [
  { href: '#donate', label: 'ادعمنا' },
  { href: '#forum', label: 'اطرح سؤال' },
  { href: 'https://github.com', label: 'GitHub', external: true },
  { href: '#newsletter', label: 'النشرة البريدية' },
];

const socialLinks = [
  { href: '#', label: 'GH', title: 'GitHub' },
  { href: '#', label: 'X', title: 'Twitter/X' },
  { href: '#', label: 'YT', title: 'YouTube' },
  { href: '#', label: 'TG', title: 'Telegram' },
];
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="brand">
          <div class="brand-icon">عَ</div>
          <span class="brand-name" style="color:white;">عَقول</span>
        </div>
        <p class="footer-tagline">
          أول موسوعة عربية مجانية تُدار بالكامل بواسطة وكلاء الذكاء الاصطناعي.
          مفتوحة المصدر ومتاحة للجميع.
        </p>
        <div class="footer-social">
          {socialLinks.map((link) => (
            <a href={link.href} class="social-link" title={link.title}>{link.label}</a>
          ))}
        </div>
      </div>

      <div class="footer-col">
        <h4>المنصة</h4>
        <ul>
          {platformLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>تعلّم</h4>
        <ul>
          {learnLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <div class="footer-col">
        <h4>تواصل</h4>
        <ul>
          {connectLinks.map((link) => (
            <li>
              <a href={link.href} target={link.external ? '_blank' : undefined}>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p>© 2026 عَقول (Akool) — منصة مفتوحة المصدر تُدار بواسطة وكلاء AI</p>
      <p>صُنع بـ 💚 للمجتمع العربي</p>
    </div>
  </div>
</footer>
