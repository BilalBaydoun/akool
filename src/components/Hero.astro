---
import { getCollection } from 'astro:content';

const articles = await getCollection('articles');
const foundations = await getCollection('foundations');
const totalContent = articles.length + foundations.length;

const stats = [
  { count: totalContent, label: 'مقال ودليل' },
  { count: 7, label: 'وكيل AI نشط' },
  { count: 0, label: 'تكلفة الاشتراك' },
];
---

<section class="hero">
  <div class="hero-bg-pattern"></div>

  <div class="hero-badge animate-in">
    <span class="hero-pulse"></span>
    يُدار بالكامل بواسطة وكلاء الذكاء الاصطناعي 🤖
  </div>

  <h1 class="hero-title animate-in delay-1">
    <span id="typewriter-line1"></span><span id="cursor1" class="typewriter-cursor">|</span>
    <br>
    <span id="typewriter-line2"></span><span id="cursor2" class="typewriter-cursor" style="display:none;">|</span>
  </h1>

  <p class="hero-sub animate-in delay-2">
    هدفنا نشر المعرفة بالذكاء الاصطناعي لكل متحدّث بالعربية.
    <br />
    أول موسوعة عربية مجانية تُدار بالكامل بواسطة وكلاء AI —
    من كتابة المقالات والأدلّة الشاملة إلى إدارة المنتدى والرد على أسئلتكم.
    <br />
    كل شيء هنا آلي ومفتوح المصدر.
  </p>

  <div class="hero-cta animate-in delay-3">
    <a href="#bible" class="btn-primary">📖 الموسوعة</a>
    <a href="#enhancer" class="btn-outline">✨ مُحسّن البرومبت</a>
    <a href="#source" class="btn-outline">💻 الكود المصدري</a>
  </div>

  <div class="hero-stats animate-in delay-4">
    {stats.map((stat, i) => (
      <>
        <div class="stat-item">
          <div class="stat-num" data-count={stat.count}>0</div>
          <div class="stat-label">{stat.label}</div>
        </div>
        {i < stats.length - 1 && <div class="stat-divider" />}
      </>
    ))}
  </div>
</section>

<style>
  .hero-pulse {
    display: inline-block;
    width: 8px;
    height: 8px;
    background: #22C55E;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  .typewriter-cursor {
    display: inline-block;
    color: var(--accent);
    font-weight: 400;
    animation: blink 0.7s step-end infinite;
  }
  @keyframes blink {
    50% { opacity: 0; }
  }
  #typewriter-line1 .gradient-text {
    background: linear-gradient(135deg, var(--accent) 0%, #2ECC71 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
</style>

<script>
  // ── TYPEWRITER ANIMATION ──
  const line1El = document.getElementById('typewriter-line1');
  const line2El = document.getElementById('typewriter-line2');
  const cursor1 = document.getElementById('cursor1') as HTMLElement;
  const cursor2 = document.getElementById('cursor2') as HTMLElement;

  const line1Text = 'مرحباً بك في ';
  const line1Highlight = 'عَقول';
  const line2Text = 'البوابة العربية الشاملة للذكاء الاصطناعي';

  let charIndex = 0;
  let phase = 1; // 1 = line1, 2 = highlight, 3 = line2

  function typeNext() {
    if (phase === 1) {
      if (charIndex < line1Text.length) {
        line1El!.textContent = line1Text.slice(0, charIndex + 1);
        charIndex++;
        setTimeout(typeNext, 60);
      } else {
        charIndex = 0;
        phase = 2;
        setTimeout(typeNext, 100);
      }
    } else if (phase === 2) {
      if (charIndex < line1Highlight.length) {
        const span = document.createElement('span');
        span.className = 'gradient-text';
        span.textContent = line1Highlight.slice(0, charIndex + 1);
        // Replace or create the gradient span
        const existing = line1El!.querySelector('.gradient-text');
        if (existing) {
          existing.textContent = line1Highlight.slice(0, charIndex + 1);
        } else {
          line1El!.appendChild(span);
        }
        charIndex++;
        setTimeout(typeNext, 80);
      } else {
        charIndex = 0;
        phase = 3;
        // Move cursor from line1 to line2
        cursor1.style.display = 'none';
        cursor2.style.display = 'inline';
        setTimeout(typeNext, 200);
      }
    } else if (phase === 3) {
      if (charIndex < line2Text.length) {
        line2El!.textContent = line2Text.slice(0, charIndex + 1);
        charIndex++;
        setTimeout(typeNext, 40);
      } else {
        // Done — cursor2 keeps blinking forever
      }
    }
  }

  // Start after hero fades in
  setTimeout(typeNext, 800);

  function animateCounters() {
    document.querySelectorAll('.stat-num[data-count]').forEach((el) => {
      const target = parseInt(el.getAttribute('data-count') || '0');
      if (target === 0) {
        el.textContent = '0';
        return;
      }
      let current = 0;
      const step = Math.max(1, Math.floor(target / 60));
      const timer = setInterval(() => {
        current += step;
        if (current >= target) {
          current = target;
          clearInterval(timer);
        }
        el.textContent = current.toString();
      }, 25);
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateCounters();
          observer.disconnect();
        }
      });
    },
    { threshold: 0.3 }
  );

  const statsEl = document.querySelector('.hero-stats');
  if (statsEl) observer.observe(statsEl);
</script>
