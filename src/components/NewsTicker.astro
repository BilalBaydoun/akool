---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية الشخصية بسرعة وبدقة عالية.',
  '📊 أعلنت شركة تقنية رائدة عن طرح منصة ذكاء اصطناعي مخصصة لتحسين أداء الشركات الصغيرة والمتوسطة.',
  '🚀 تم إطلاق مشروع بحثي جديد يستخدم الذكاء الاصطناعي لتحليل البيانات الفلكية وتحسين فهم الظواهر الكونية.',
  '💻 أعلن فريق من الباحثين عن اختراع روبوت جديد يعتمد على الذكاء الاصطناعي لتنفيذ مهام复杂ة في مجال الصناعة.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في مجال التعليم يمكن أن يزيد من نسبة نجاح الطلاب بنسبة 25%.',
];
---

<div class="news-ticker">
  <div class="ticker-label">🔴 عاجل</div>
  <div class="ticker-track">
    <div class="ticker-inner">
      {newsItems.map((item) => <span>{item}</span>)}
      {newsItems.map((item) => <span>{item}</span>)}
    </div>
  </div>
</div>
