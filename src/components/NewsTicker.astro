---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة وبدقة أكبر في عام 2026.',
  '📊 أعلنت شركة تقنية رائدة عن إطلاق منصة تعلم الآلة مفتوحة المصدر لتسهيل تطوير التطبيقات الذكية في شهر يوليو 2026.',
  '🚀 استخدمت وكالة فضاء أوروبية الذكاء الاصطناعي في تطوير أنظمة دفع متقدمة للرواد الفضائية في مشاريعها الأخيرة.',
  '💻 طور باحثون نظام ذكاء اصطناعي يمكنه كتابة البرامج بسهولة أكبر، مما يفتح آفاقًا جديدة في مجال البرمجة في عام 2026.',
