---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية بسرعة ودقة أعلى من الأنظمة السابقة.',
  '📊 أعلنت شركة تقنية رائدة عن إطلاق منصة تعلم آلي جديدة تتيح للمستخدمين تطوير نماذج الذكاء الاصطناعي بسهولة.',
  '📈 وفقًا لتقرير حديث، من المتوقع أن يصل سوق الذكاء الاصطناعي إلى قيمة 500 مليار دولار في عام 2026.',
  '💻 تم استخدام الذكاء الاصطناعي في تطوير نظام أمان جديد يمكنه حماية الشبكات من الهجمات الإلكترونية بفعالية أكبر.',
  '🚀 أعلنت وكالة فضاء عن خطط لاستخدام الذكاء الاصطناعي في تطوير أنظمة مراقبة جديدة لتحسين أمان الرحلات الفضائية.',
