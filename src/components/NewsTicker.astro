---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية بفعالية أكبر في المستشفيات.',
  '💻 أعلنت شركة تكنولوجيا رائدة عن إطلاق منصة تعليمية تستخدم الذكاء الاصطناعي لتدريب المطورين على البرمجة.',
  '📊 استخدمت شركة كبيرة في قطاع الخدمات المالية نظامًا مبتكرًا من الذكاء الاصطناعي لتحسين خدماتها المصرفية عبر الإنترنت.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في الشركات يمكن أن يزيد من إنتاجيتها بنسبة تصل إلى 30%.',
  '🔍 طور باحثون نظام ذكاء اصطناعي يمكنه الكشف عن الأمراض المزمنة مبكرًا باستخدام بيانات الصحة العامة.',
];
