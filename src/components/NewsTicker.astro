---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة ودقة أعلى من البشر.',
  '📊 أعلنت شركة تقنية رائدة عن إطلاق منصة ذكاء اصطناعي مخصصة لتحسين عمليات الأعمال التجارية في الشرق الأوسط.',
  '🚀 تم استخدام الذكاء الاصطناعي في تطوير مركبة فضائية جديدة قادرة على استكشاف كواكب بعيدة بفعالية أكبر.',
  '📚 أطلقت جامعة عربية مشروعًا لاستخدام الذكاء الاصطناعي في تطوير أنظمة تعليمية تفاعلية لتحسين جودة التعلم.',
  '💻 تم تطوير تطبيق ذكاء اصطناعي يمكنه مساعدة الأشخاص على تحسين صحة عقولهم من خلال تقنيات التأمل والاسترخاء.',
];
