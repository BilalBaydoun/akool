---
const newsItems = [
  '🤖 تم إطلاق نظام ذكاء اصطناعي جديد لتحسين كفاءة المرور في المدن العربية.',
  '📊 أعلنت شركة تقنية رائدة عن تطوير برنامج ذكاء اصطناعي لتحليل البيانات المالية بتقنيات متقدمة.',
  '🚀 استخدمت وكالة فضاء أوروبية الذكاء الاصطناعي لتحسين دقة توقعات الطقس الفضائي في عام 2026.',
  '📚 تم تطوير منصة تعلم إلكترونية تعتمد على الذكاء الاصطناعي لتحسين تجربة الطلاب في المدارس العربية.',
  '💻 أعلنت جامعة أمريكية عن إطلاق برنامج جديد لتدريب الخبراء على تقنيات الذكاء الاصطناعي وتطبيقاتها العملية.',
];
