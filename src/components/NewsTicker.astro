---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية لمرضى السكر بنسبة دقة تصل إلى 95% في عام 2026.',
  '💻 شركة تكنولوجيا أمريكية تطلق منصة تعليمية متقدمة تعتمد على الذكاء الاصطناعي لتدريب المهنيين في مجال البرمجة.',
  '📊 باحثون في جامعة عربية ينجحون في تطوير خوارزمية ذكاء اصطناعي لتحليل البيانات المالية وتوقعات الأسواق المالية بدقة عالية.',
  '🚀 شركة طيران أوروبية تتبنى نظام ذكاء اصطناعي لتحسين كفاءة إدارة حركة الطائرات وتقليل التأخيرات الجوية.',
  '📈 شركة تقنية عربية تطرح تطبيق ذكاء اصطناعي لمساعدة الأشخاص في إدارة أمورهم اليومية وتحسين إنتاجيتهم الشخصية.',
];
