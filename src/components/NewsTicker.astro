---
const newsItems = [
  '🚀 أعلنت شركة غوغل عن إطلاق تحديث جديد لبرنامجها للترجمة الفورية باستخدام الذكاء الاصطناعي، مما يعزز دقة الترجمة بنسبة 30%.',
  '🤖 تم تطوير روبوت جديد يستخدم الذكاء الاصطناعي لتقديم المساعدة في عمليات البحث والإنقاذ في المناطق الزلزالية.',
  '💻 أعلنت جامعة ستانفورد عن إطلاق برنامج جديد لتعليم الذكاء الاصطناعي وتطبيقاته في مجال الصحة العامة.',
  '📊 استخدمت شركة أمازون الذكاء الاصطناعي لتحسين خدماتها اللوجستية، مما خفض التكاليف بنسبة 25% في الربع الأول من عام 2026.',
