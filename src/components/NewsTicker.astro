---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية بسرعة ودقة أعلى من الأنظمة السابقة.',
  '📊 أعلنت شركة تقنية رائدة عن إطلاق منصة تعلم الآلة مفتوحة المصدر لتسهيل تطوير التطبيقات الذكية.',
  '🚀 تم استخدام الذكاء الاصطناعي في تطوير مركبة فضائية جديدة تهدف إلى استكشاف كوكب المريخ في عام 2028.',
  '💻 تطوير خوارزمية جديدة لتحليل البيانات الضخمة باستخدام تقنيات الذكاء الاصطناعي لتحسين أداء الشبكات الاجتماعية.',
