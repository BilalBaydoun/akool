---
const newsItems = [
  '🤖 أعلنت شركة جوجل عن إطلاق تقنية جديدة للذكاء الاصطناعي تتيح التحكم في السيارات ذاتية القيادة بدقة أعلى.',
  '📊 تم تطوير نظام ذكاء اصطناعي لتحليل البيانات الصحية وتحسين دقة التشخيص الطبي في المستشفيات حول العالم.',
  '🚀 استخدمت ناسا تقنيات الذكاء الاصطناعي لتحسين دقة توقعات الطقس وتحليل البيانات الفضائية.',
  '💻 طورت جامعة كاليفورنيا نظام ذكاء اصطناعي يمكنه تعلم اللغات بسرعة وكفاءة أكبر من الأنظمة الحالية.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في الشركات يزيد من الإنتاجية بنسبة 30% ويحسن جودة المنتجات.',
];
