const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية لمرضى السكري بدرجة دقة عالية في جامعة هارڤرد الأمريكية.',
  '💻 شركة مايكروسوفت تعلن عن إطلاق منصة جديدة للتعلم الالكتروني تعتمد على الذكاء الاصطناعي لتحسين تجربة المستخدمين.',
  '📊 باحثون في جامعة كامبريدج ينجحون في تطوير خوارزمية ذكاء اصطناعي لتنبؤ بالزلازل بدرجة دقة عالية.',
  '🚀 شركة إسباسي إكس تعلن عن خططها لاستخدام الذكاء الاصطناعي في تطوير أنظمة الملاحة الفضائية لتحسين دقة الرحلات الفضائية.',
