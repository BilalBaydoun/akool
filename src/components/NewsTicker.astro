---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة وبدقة أعلى من الأطباء البشر.',
  '💻 شركة تقنية رائدة تعلن عن إطلاق منصة تعلم الآلة مفتوحة المصدر للمطورين في جميع أنحاء العالم.',
  '📊 باحثون يطورون خوارزمية ذكاء اصطناعي لتوقعات الطقس الدقيقة باستخدام البيانات الحية من الأقمار الصناعية.',
  '🚀 شركة ناسا تعلن عن مشروع جديد لاستخدام الذكاء الاصطناعي في تطوير أنظمة تحكم مركبات الفضاء.',
