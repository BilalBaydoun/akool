---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه ترجمة اللغات بسرعة وبدقة عالية في جامعة كاليفورنيا.',
  '📊 أعلنت شركة مايكروسوفت عن إطلاق منصة تعليمية جديدة تعتمد على الذكاء الاصطناعي لتعليم البرمجة للأطفال.',
  '🚀 تم إطلاق رواد الفضاء إلى الفضاء باستخدام نظام ذكاء اصطناعي لتحسين أداء المركبة الفضائية وتحقيق أمان الرحلة.',
  '💻 تم تطوير برنامج ذكاء اصطناعي يمكنه كتابة البرامج بسرعة وبدقة عالية، مما يقلل من الحاجة للمبرمجين البشريين.',
