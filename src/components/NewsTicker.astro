---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة وبدقة عالية في المستشفيات.',
  '📊 أعلنت شركة تقنية رائدة عن إطلاق منصة تعلم الآلة مخصصة لتحسين أداء الأعمال في الشركات الصغيرة.',
  '🚀 تم استخدام الذكاء الاصطناعي في تطوير مركبة فضائية جديدة قادرة على استكشاف الكواكب البعيدة بفعالية أكبر.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في التسويق يمكن أن يزيد من مبيعات الشركات بنسبة تصل إلى 30%.',
  '🔒 تم تطوير نظام أمان جديد يستخدم الذكاء الاصطناعي لتحليل البيانات واكتشاف التهديدات السيبرانية بفعالية أكبر.',
];
