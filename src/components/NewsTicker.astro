---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية بشكل أسرع وأكثر دقة من الأنظمة السابقة.',
  '💻 أعلنت شركة تكنولوجيا رائدة عن إطلاق منصة تعليمية جديدة تعتمد على الذكاء الاصطناعي لتدريب المطورين على البرمجة.',
  '📊 استخدمت شركة طيران كبيرة الذكاء الاصطناعي لتطوير نظام تحليل البيانات لتحسين كفاءة رحلاتها وتقليل التأخيرات.',
  '📚 تم تطوير روبوت جديد يعتمد على الذكاء الاصطناعي يمكنه مساعدة المكفوفين في القراءة والكتابة.',
  '👥 أعلن فريق بحثي عن اكتشاف طريقة جديدة لاستخدام الذكاء الاصطناعي في تحسين أمان الشبكات الاجتماعية وتحديد المحتوى المزيف.',
