---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه فهم اللغة الطبيعية بدرجة عالية من الدقة في جامعة كاليفورنيا.',
  '💻 أعلنت شركة مايكروسوفت عن إطلاق منصة جديدة لتعليم الذكاء الاصطناعي ومواده الدراسية المجانيه على الإنترنت.',
  '📊 تم إطلاق مشروع بحثي جديد في جامعة هارفارد لاستخدام الذكاء الاصطناعي في تحليل البيانات الطبية وتحسين التشخيص.',
  '🚀 أعلنت وكالة ناسا عن استخدام الذكاء الاصطناعي في تحليل البيانات الفضائية وتحسين مهمات الفضاء.',
