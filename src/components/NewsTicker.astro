---
const newsItems = [
  '🚀 أعلنت شركة جوجل عن إطلاق نظام الذكاء الاصطناعي الجديد الذي يمكنه فهم اللغة الطبيعية بدرجة أعلى من السابق.',
  '💻 تم تطوير روبوت جديد يستخدم الذكاء الاصطناعي لتحسين عمليات الإنتاج في المصانع الصناعية حول العالم.',
  '📊 استخدمت شركة أمازون الذكاء الاصطناعي لتحسين خدماتها اللوجستية وتسريع عمليات الشحن والتوصيل.',
  '🤖 طور باحثون نظامًا جديدًا للذكاء الاصطناعي يمكنه التعلم من الأخطاء وتحسين أدائه بمرور الوقت.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في مجال الرعاية الصحية يمكن أن يقلل من الأخطاء الطبية ويحسن النتائج الصحية للمرضى.',
