---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الصحية بفعالية أكبر في المستشفيات العربية.',
  '💻 شركة تكنولوجيا رائدة تعلن عن إطلاق منصة تعليمية مجانية لتعليم الذكاء الاصطناعي في المدارس الثانوية.',
  '📊 باحثون يطورون خوارزمية ذكاء اصطناعي لتحسين دقة التنبؤ بالطقس في منطقة الشرق الأوسط.',
  '🚀 شركة ناسا تعلن عن استخدام الذكاء الاصطناعي في تحليل البيانات الفضائية لتحسين فهم الفضاء.',
