---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة ودقة أكبر من الأنظمة السابقة.',
  '📊 أعلنت شركة تكنولوجيا رائدة عن إطلاق منصة تعليمية تعتمد على الذكاء الاصطناعي لتدريب المطورين على البرمجة.',
  '🚀 استخدمت وكالة فضاء أوروبية الذكاء الاصطناعي في تطوير نظام توجيه للمركبات الفضائية لتحسين دقة المناورات.',
  '💻 طور باحثون نظام ذكاء اصطناعي يمكنه الكشف عن الهجمات الإلكترونية المتقدمة بفعالية أكبر.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في مجال التسويق يمكن أن يزيد من فعالية الحملات الإعلانية بنسبة 30%.',
];
