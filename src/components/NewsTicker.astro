---
const newsItems = [
  '🤖 تم إطلاق نظام ذكاء اصطناعي جديد لتحسين كفاءة إدارة المرور في المدن العربية.',
  '💻 طور باحثون عرب أجهزة كمبيوتر صغيرة تعمل بالذكاء الاصطناعي لتسريع عمليات التحليل العلمي.',
  '📊 أعلنت شركة تقنية رائدة في الشرق الأوسط عن تطوير برنامج ذكاء اصطناعي لتحليل البيانات المالية.',
  '🚀 استخدمت وكالة فضاء عربية الذكاء الاصطناعي في تطوير أنظمة دقيقة لمراقبة الطقس والمناخ.',
  '📚 طور فريق من العلماء نظامًا ذكياً لتحليل النصوص العربية القديمة وتحويلها إلى صيغ رقمية حديثة.',
];
---

<div class="news-ticker">
  <div class="ticker-label">🔴 عاجل</div>
  <div class="ticker-track">
    <div class="ticker-inner">
      {newsItems.map((item) => <span>{item}</span>)}
      {newsItems.map((item) => <span>{item}</span>)}
    </div>
  </div>
</div>
