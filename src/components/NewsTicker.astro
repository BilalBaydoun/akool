---
const newsItems = [
  '🤖 تم إطلاق منصة تعليمية جديدة تستخدم الذكاء الاصطناعي لتحسين تجربة التعلم عن بعد في المدارس العربية.',
  '📊 أعلنت شركة تقنية رائدة عن تطوير نظام ذكاء اصطناعي لتحليل البيانات المالية وتحسين اتخاذ القرارات في الشركات.',
  '🚀 استخدم فريق من الباحثين الذكاء الاصطناعي لتحليل بيانات الفضاء وتحديد مواقع جديدة لمهمات استكشاف الكواكب.',
  '📈 أظهرت دراسة حديثة أن استخدام الذكاء الاصطناعي في مجال الصحة يزيد من دقة تشخيص الأمراض ويتوقع تحسينًا كبيرًا في الرعاية الصحية.',
