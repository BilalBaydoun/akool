---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة و دقة عالية في جامعة كاليفورنيا.',
  '📊 شركة مايكروسوفت تعلن عن إطلاق منصة جديدة للتعلم الآلي تهدف إلى دعم الشركات الصغيرة في تطوير تطبيقات الذكاء الاصطناعي.',
  '🚀 وكالة ناسا تعتمد تقنيات الذكاء الاصطناعي لتحسين أنظمة الطيران الآلي في المركبات الفضائية.',
  '💻 باحثون في جامعة ستانفورد ينجحون في تطوير خوارزمية ذكاء اصطناعي يمكنها تحليل اللغة الطبيعية بفهم أعمق للسياق.',
  '📈 شركة غوغل تعلن عن تحديثات جديدة لمنصة تينسورفلو لتسريع تطوير تطبيقات الذكاء الاصطناعي في مجال الرؤية الحاسوبية.',
