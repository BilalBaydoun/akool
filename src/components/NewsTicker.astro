---
const newsItems = [
  '🤖 تم تطوير نظام ذكاء اصطناعي جديد يمكنه تحليل البيانات الطبية بسرعة ودقة أعلى من الأنظمة السابقة.',
  '💻 شركة تقنية رائدة تعلن عن إطلاق منصة تعلم الآلة مفتوحة المصدر للمطورين في جميع أنحاء العالم.',
  '📊 باحثون ينجحون في تطوير خوارزمية ذكاء اصطناعي لتحليل السلوك الإنساني وتوقعاته بتقنيات متقدمة.',
  '🚀 شركة ناسا تعلن عن استخدامها لتكنولوجيا الذكاء الاصطناعي في تطوير أنظمة مراقبة جوية متقدمة.',
