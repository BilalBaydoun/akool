    difficulty: 'متقدم',
    duration: 'يوم واحد',
    color: 'var(--accent-light)',
    textColor: 'var(--accent)',
    steps: [
      'تحديد الفكرة والخطة مع AI',
      'تصميم CSS وهيكل الصفحات',
      'بناء 20+ مكوّن Astro',
      'كتابة 8 مقالات بالعربي',
      'إضافة نظام التعلّم والاختبارات',
      'بناء 7 وكلاء AI وظيفيين',
      'النشر على Vercel',
    ],
    result: 'منصة عربية كاملة بـ 40+ صفحة، 7 وكلاء AI، نظام تعلّم، منتدى — بتكلفة $0',
    link: '/source',
  },
  {
    emoji: '📧',
    title: 'أتمتة الردود على إيميلات العملاء',
    description: 'نظام يقرأ إيميلات العملاء ويصنّفها ويرد عليها تلقائياً باستخدام AI.',
    tools: ['ChatGPT API', 'Zapier', 'Gmail'],
    difficulty: 'متوسط',
    duration: '3 ساعات',
    color: 'var(--blue-light)',
    textColor: 'var(--blue)',
    steps: [
      'ربط Gmail مع Zapier',
      'إرسال الإيميل الوارد لـ ChatGPT API',
      'تصنيف الإيميل: استفسار / شكوى / طلب',
      'توليد رد مناسب بناءً على التصنيف',
      'إرسال الرد تلقائياً أو حفظه كمسودة',
    ],
    result: 'توفير 2+ ساعة يومياً من الردود اليدوية — دقة 90% في التصنيف',
  },
  {
    emoji: '🎨',
    title: 'متجر تيشيرتات مصممة بـ AI',
    description: 'كيف تبني متجراً لبيع تصاميم تيشيرتات مولّدة بالذكاء الاصطناعي على Redbubble.',
    tools: ['Midjourney', 'Canva', 'Redbubble'],
    difficulty: 'مبتدئ',
    duration: '5 ساعات',
    color: 'var(--purple-light)',
    textColor: 'var(--purple)',
    steps: [
      'اختيار نيش (مثل: تصاميم عربية، قطط، فضاء)',
      'توليد 20 تصميم بـ Midjourney',
      'تحسين التصاميم في Canva (إزالة خلفية، إضافة نص)',
      'رفع التصاميم على Redbubble',
      'كتابة أوصاف وتاقات بـ ChatGPT',
      'مشاركة على السوشيال ميديا',
    ],
    result: 'متجر جاهز بـ 20 تصميم — بعض البائعين يحققون 500-2000$/شهر',
  },
  {
    emoji: '📹',
    title: 'قناة يوتيوب بدون ظهور باستخدام AI',
    description: 'إنشاء قناة يوتيوب كاملة — من السكريبت للصوت للمونتاج — كل شيء بـ AI.',
    tools: ['ChatGPT', 'ElevenLabs', 'CapCut', 'Canva'],
    difficulty: 'متوسط',
    duration: 'يوم واحد',
    color: 'var(--rose-light)',
    textColor: 'var(--rose)',
    steps: [
      'اختيار نيش (مثل: حقائق، تاريخ، تقنية)',
      'كتابة سكريبت الفيديو بـ ChatGPT',
      'توليد الصوت بـ ElevenLabs (عربي أو إنجليزي)',
      'تصميم صور وأغلفة بـ Canva AI',
      'مونتاج الفيديو بـ CapCut (قوالب جاهزة)',
