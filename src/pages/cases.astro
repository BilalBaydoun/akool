---

<BaseLayout title="مشاريع عملية — عَقول" description="مشاريع حقيقية بُنيت بالذكاء الاصطناعي مع شرح خطوة بخطوة">
  <Navbar />
  <SearchModal />

  <section class="section" style="padding-top:calc(var(--nav-h) + 40px);">
    <div class="container">
      <div class="section-header">
        <div class="section-tag">🏗️ مشاريع عملية</div>
        <h2 class="section-title">مشاريع حقيقية بُنيت بـ AI</h2>
        <p class="section-sub">تعلّم من مشاريع حقيقية — كل مشروع مشروح خطوة بخطوة مع الأدوات المستخدمة</p>
      </div>

      <div class="cases-grid">
        {cases.map((c) => (
          <div class="case-card">
            <div class="case-header" style={`background:${c.color};`}>
              <span style="font-size:2.5rem;">{c.emoji}</span>
              <div class="case-badges">
                <span class="case-badge" style={`color:${c.textColor};`}>📊 {c.difficulty}</span>
                <span class="case-badge" style={`color:${c.textColor};`}>⏱ {c.duration}</span>
              </div>
            </div>

            <div class="case-body">
              <h3 class="case-title">{c.title}</h3>
              <p class="case-desc">{c.description}</p>

              <div class="case-tools">
                {c.tools.map((tool) => (
                  <span class="case-tool">{tool}</span>
                ))}
              </div>

              <h4 class="case-section-title">📋 الخطوات</h4>
              <ol class="case-steps">
                {c.steps.map((step) => (
                  <li>{step}</li>
                ))}
              </ol>

              <div class="case-result">
                <strong>💡 النتيجة:</strong> {c.result}
              </div>

              {c.link && (
                <a href={c.link} class="btn-primary" style="display:inline-flex;margin-top:1rem;padding:8px 20px;font-size:0.85rem;border-radius:50px;">
                  شاهد المشروع ←
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div class="enhancer-card" style="text-align:center;margin-top:3rem;">
        <div style="font-size:2rem;margin-bottom:0.75rem;">💡</div>
        <h3 style="font-size:1.1rem;font-weight:800;margin-bottom:0.75rem;">عندك مشروع بنيته بـ AI؟</h3>
        <p style="color:var(--text-muted);margin-bottom:1.5rem;line-height:1.8;">شاركنا مشروعك وسنضيفه هنا مع ذكر اسمك كمساهم</p>
        <a href="/submit" class="btn-primary" style="padding:10px 24px;font-size:0.95rem;border-radius:50px;">📤 شارك مشروعك</a>
      </div>
    </div>
  </section>

  <Footer />
  <ChatWidget />
</BaseLayout>

<style>
  .cases-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 24px;
  }
  .case-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-xl);
    overflow: hidden;
    transition: all 0.3s;
  }
  .case-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: transparent;
  }
  .case-header {
    padding: 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .case-badges {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-end;
  }
  .case-badge {
    font-size: 0.75rem;
    font-weight: 700;
    background: rgba(255,255,255,0.7);
    padding: 3px 12px;
    border-radius: 50px;
  }
  .case-body {
    padding: 1.5rem 2rem 2rem;
  }
  .case-title {
    font-size: 1.15rem;
    font-weight: 800;
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }
  .case-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .case-tools {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }
  .case-tool {
    background: var(--surface2);
    color: var(--text-muted);
    border-radius: 50px;
    padding: 3px 12px;
    font-size: 0.75rem;
    font-weight: 600;
  }
  .case-section-title {
    font-size: 0.9rem;
    font-weight: 700;
    margin-bottom: 0.6rem;
  }
  .case-steps {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 1.25rem;
    padding-right: 1.25rem;
  }
  .case-steps li {
    font-size: 0.85rem;
    color: var(--text-2);
    line-height: 1.7;
  }
  .case-result {
    background: var(--accent-light);
    border-right: 3px solid var(--accent);
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    color: var(--text-2);
    line-height: 1.7;
  }
  @media (max-width: 768px) {
    .cases-grid { grid-template-columns: 1fr; }
  }
</style>
