---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import SearchModal from '../../components/SearchModal.astro';
import { learningPaths } from '../../data/learning-paths';
---

<BaseLayout title="تعلّم AI — عَقول">
  <Navbar />
  <SearchModal />

  <section class="section" style="padding-top:calc(var(--nav-h) + 60px);">
    <div class="container">
      <div style="text-align:center;margin-bottom:3rem;">
        <div style="font-size:3rem;margin-bottom:1rem;">🎓</div>
        <h1 style="font-size:clamp(1.8rem,4vw,2.5rem);font-weight:900;margin-bottom:1rem;">
          تعلّم <span class="gradient-text">الذكاء الاصطناعي</span> خطوة بخطوة
        </h1>
        <p style="color:var(--text-muted);font-size:1.05rem;max-width:500px;margin:0 auto;line-height:1.8;">
          مسارات تعليمية منظمة مع دروس قصيرة واختبارات تفاعلية — تعلّم بالسرعة التي تناسبك
        </p>
      </div>

      <div class="library-grid">
        {learningPaths.map((path) => (
          <a href={`/learn/${path.id}`} class="lib-card" style="text-decoration:none;">
            <div class="lib-icon" style={`background:${path.color};color:${path.textColor};`}>
              {path.emoji}
            </div>
            <div style="display:flex;align-items:center;gap:8px;margin-bottom:0.5rem;">
              <h3 style="margin:0;">{path.title}</h3>
              <span class="blog-tag" style={`background:${path.color};color:${path.textColor};`}>{path.level}</span>
            </div>
            <p>{path.description}</p>
            <div style="display:flex;gap:12px;margin-bottom:1rem;font-size:0.82rem;color:var(--text-muted);">
              <span>📚 {path.lessons.length} دروس</span>
              <span>⏱ {path.totalDuration}</span>
            </div>
            <div style="height:6px;background:var(--surface3);border-radius:3px;overflow:hidden;margin-bottom:1rem;">
              <div class="learn-progress-bar" data-path={path.id} style="height:100%;width:0%;background:var(--accent);border-radius:3px;transition:width 0.5s;"></div>
            </div>
            <span class="lib-link">ابدأ التعلّم ←</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  document.querySelectorAll('.learn-progress-bar').forEach((bar) => {
    const pathId = (bar as HTMLElement).dataset.path || '';
    try {
      const saved = JSON.parse(localStorage.getItem(`akool-learn-${pathId}`) || '{}');
      const completed = saved.completedLessons?.length || 0;
      const total = bar.closest('.lib-card')?.querySelector('[class*="دروس"]')?.textContent?.match(/\d+/)?.[0] || '5';
      const pct = (completed / parseInt(total)) * 100;
      (bar as HTMLElement).style.width = pct + '%';
    } catch {}
  });
</script>
