---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
---

<BaseLayout title="تسجيل الدخول — عَقول">
  <Navbar />
  <SearchModal />

  <section class="section" style="padding-top:calc(var(--nav-h) + 60px);min-height:80vh;">
    <div class="container" style="max-width:480px;">

      <!-- Login Form -->
      <div id="loginView">
        <div style="text-align:center;margin-bottom:2rem;">
          <div class="brand" style="justify-content:center;margin-bottom:1rem;">
            <div class="brand-icon" style="width:52px;height:52px;font-size:1.4rem;">عَ</div>
          </div>
          <h1 style="font-size:1.6rem;font-weight:900;margin-bottom:0.5rem;">سجّل الدخول إلى عَقول</h1>
          <p style="color:var(--text-muted);font-size:0.95rem;">ادخل إلى حسابك وشارك في المجتمع</p>
        </div>

        <div class="enhancer-card">
          <label class="enhancer-label">البريد الإلكتروني</label>
          <input type="email" id="loginEmail" class="form-input" placeholder="you@example.com" dir="ltr" style="margin-bottom:16px;">

          <label class="enhancer-label">كلمة المرور</label>
          <input type="password" id="loginPassword" class="form-input" placeholder="••••••••" style="margin-bottom:20px;">

          <button id="loginBtn" class="btn-enhance" style="border-radius:50px;">تسجيل الدخول</button>

          <div style="display:flex;align-items:center;gap:12px;margin:20px 0;">
            <div style="flex:1;height:1px;background:var(--border);"></div>
            <span style="font-size:0.82rem;color:var(--text-light);white-space:nowrap;">أو سجّل عبر</span>
            <div style="flex:1;height:1px;background:var(--border);"></div>
          </div>

          <div style="display:flex;gap:12px;">
            <button id="googleLoginBtn" class="social-auth-btn" style="flex:1;">
              <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
              Google
            </button>
            <button id="appleLoginBtn" class="social-auth-btn" style="flex:1;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
              Apple
            </button>
          </div>

          <div id="loginError" class="hidden" style="margin-top:12px;padding:10px 14px;background:var(--rose-light);color:var(--rose);border-radius:var(--radius-sm);font-size:0.85rem;font-weight:600;"></div>

          <div style="text-align:center;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);">
            <p style="font-size:0.9rem;color:var(--text-muted);">
              ليس لديك حساب؟
              <a href="/register" style="color:var(--accent);font-weight:700;">أنشئ حساباً مجانياً</a>
            </p>
          </div>
        </div>
      </div>

      <!-- Profile (shown when logged in) -->
      <div id="profileView" class="hidden">
        <div style="text-align:center;margin-bottom:2rem;">
          <h1 style="font-size:1.6rem;font-weight:900;margin-bottom:0.5rem;">ملفي الشخصي</h1>
        </div>

        <div class="enhancer-card">
          <div style="display:flex;flex-direction:column;align-items:center;gap:12px;padding:24px 0;margin-bottom:20px;background:var(--surface2);border-radius:var(--radius);text-align:center;">
            <div id="profileAvatar" style="width:72px;height:72px;border-radius:50%;background:var(--accent-light);color:var(--accent);display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;">👤</div>
            <div style="display:flex;align-items:center;gap:8px;">
              <span id="profileName" style="font-size:1.2rem;font-weight:800;">—</span>
              <span id="profileBadge" class="hidden" style="font-size:0.72rem;font-weight:700;padding:2px 10px;border-radius:50px;"></span>
            </div>
            <span id="profileEmail" style="font-size:0.85rem;color:var(--text-muted);">—</span>
          </div>

          <div style="padding:16px 0;border-top:1px solid var(--border);">
            <h4 style="font-size:0.95rem;font-weight:700;margin-bottom:8px;">💰 التبرعات</h4>
            <p id="donationInfo" style="font-size:0.88rem;color:var(--text-muted);">لم تتبرع بعد</p>
            <div id="donationToggle" style="display:none;margin-top:8px;">
              <label style="display:flex;align-items:center;gap:8px;font-size:0.85rem;cursor:pointer;">
                <input type="checkbox" id="showDonationCheck">
                إظهار مبلغ التبرع في ملفي الشخصي
              </label>
            </div>
            <a href="/#donate" class="btn-primary" style="margin-top:12px;display:inline-flex;padding:8px 20px;font-size:0.85rem;border-radius:50px;">❤ تبرّع الآن</a>
          </div>

          <div style="padding:16px 0;border-top:1px solid var(--border);">
            <h4 style="font-size:0.95rem;font-weight:700;margin-bottom:8px;">👤 ملفي الشخصي</h4>
            <a id="myProfileLink" href="/profile" class="btn-outline" style="padding:8px 20px;font-size:0.85rem;border-radius:50px;display:inline-flex;margin-bottom:12px;">عرض ملفي الشخصي العام</a>
          </div>

          <div style="padding:16px 0;border-top:1px solid var(--border);">
            <h4 style="font-size:0.95rem;font-weight:700;margin-bottom:8px;">📤 مشاركاتي</h4>
            <div style="display:flex;gap:10px;flex-wrap:wrap;">
              <a href="/submit" class="btn-outline" style="padding:8px 20px;font-size:0.85rem;border-radius:50px;">شارك محتوى</a>
              <a href="/bookmarks" class="btn-outline" style="padding:8px 20px;font-size:0.85rem;border-radius:50px;">🔖 المحفوظات</a>
            </div>
          </div>

          <button id="logoutBtn" style="width:100%;margin-top:1.5rem;padding:12px;border-radius:50px;background:none;border:1.5px solid var(--rose);color:var(--rose);font-weight:700;font-family:var(--font);font-size:0.9rem;cursor:pointer;transition:all 0.2s;">
            تسجيل الخروج
          </button>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  const loginView = document.getElementById('loginView') as HTMLElement;
  const profileView = document.getElementById('profileView') as HTMLElement;

  let sb: any = null;
  async function getSupabase() {
    if (sb) return sb;
    try {
      const mod = await import('../lib/supabase');
      sb = mod.supabase;
      if (!sb.supabaseUrl || sb.supabaseUrl === '') sb = null;
      return sb;
    } catch { return null; }
  }

  function showError(msg: string) {
    const el = document.getElementById('loginError') as HTMLElement;
    el.textContent = msg;
    el.classList.remove('hidden');
  }

  // Login
  document.getElementById('loginBtn')?.addEventListener('click', async () => {
    const email = (document.getElementById('loginEmail') as HTMLInputElement).value.trim();
    const password = (document.getElementById('loginPassword') as HTMLInputElement).value;

    if (!email || !password) { showError('يرجى ملء جميع الحقول'); return; }

    const supabase = await getSupabase();
    if (!supabase) { showError('⚠️ التسجيل يحتاج إعداد Supabase — سيتم تفعيله بعد الاستضافة'); return; }

    try {
      const { error } = await supabase.auth.signInWithPassword({ email, password });
      if (error) { showError('خطأ: ' + error.message); }
      else { loadProfile(); }
    } catch { showError('⚠️ حدث خطأ في الاتصال'); }
  });

  // Logout
  document.getElementById('logoutBtn')?.addEventListener('click', async () => {
    const supabase = await getSupabase();
    if (supabase) { try { await supabase.auth.signOut(); } catch {} }
    loginView.classList.remove('hidden');
    profileView.classList.add('hidden');
  });

  // Show donation toggle
  document.getElementById('showDonationCheck')?.addEventListener('change', async (e) => {
    const supabase = await getSupabase();
    if (!supabase) return;
    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (user) await supabase.from('profiles').update({ show_donation: (e.target as HTMLInputElement).checked }).eq('id', user.id);
    } catch {}
  });

  const badgeLabels: Record<string, string> = { bronze: '🥉 برونزي', silver: '🥈 فضي', gold: '🥇 ذهبي', platinum: '💎 بلاتيني' };
  const badgeColors: Record<string, string> = { bronze: 'background:#FEF3C7;color:#92400E', silver: 'background:#F1F5F9;color:#475569', gold: 'background:#FEF9C3;color:#854D0E', platinum: 'background:#EDE9FE;color:#6D28D9' };

  async function loadProfile() {
    const supabase = await getSupabase();
    if (!supabase) return;

    try {
      const { data: { user } } = await supabase.auth.getUser();
      if (!user) return;

      loginView.classList.add('hidden');
      profileView.classList.remove('hidden');

      const { data: profile } = await supabase.from('profiles').select('*').eq('id', user.id).single();
      if (profile) {
        (document.getElementById('profileName') as HTMLElement).textContent = profile.username;
        (document.getElementById('profileEmail') as HTMLElement).textContent = user.email || '';
        (document.getElementById('profileAvatar') as HTMLElement).textContent = profile.username[0];
        const profileLink = document.getElementById('myProfileLink') as HTMLAnchorElement;
        if (profileLink) profileLink.href = `/profile?user=${encodeURIComponent(profile.username)}`;

        const badgeEl = document.getElementById('profileBadge') as HTMLElement;
        if (profile.badge) {
          badgeEl.textContent = badgeLabels[profile.badge] || profile.badge;
          badgeEl.setAttribute('style', `${badgeColors[profile.badge] || ''};font-size:0.72rem;font-weight:700;padding:2px 10px;border-radius:50px;`);
          badgeEl.classList.remove('hidden');
        }

        if (profile.is_donor) {
          (document.getElementById('donationInfo') as HTMLElement).textContent =
            profile.show_donation ? `تبرعت بـ $${profile.donation_amount}` : 'أنت متبرع 💚';
          (document.getElementById('donationToggle') as HTMLElement).style.display = 'block';
          (document.getElementById('showDonationCheck') as HTMLInputElement).checked = profile.show_donation;
        }
      }
    } catch {}
  }

  // Social login
  async function socialLogin(provider: 'google' | 'apple') {
    const supabase = await getSupabase();
    if (!supabase) { showError('⚠️ نظام التسجيل قيد الإعداد'); return; }
    try {
      const { error } = await supabase.auth.signInWithOAuth({
        provider,
        options: { redirectTo: window.location.origin + '/login' },
      });
      if (error) showError('خطأ: ' + error.message);
    } catch { showError('⚠️ حدث خطأ في الاتصال'); }
  }

  document.getElementById('googleLoginBtn')?.addEventListener('click', () => socialLogin('google'));
  document.getElementById('appleLoginBtn')?.addEventListener('click', () => socialLogin('apple'));

  // Check on load
  loadProfile();
</script>
