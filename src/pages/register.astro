---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import SearchModal from '../components/SearchModal.astro';
---

<BaseLayout title="إنشاء حساب — عَقول">
  <Navbar />
  <SearchModal />

  <section class="section" style="padding-top:calc(var(--nav-h) + 60px);min-height:80vh;">
    <div class="container" style="max-width:480px;">

      <div style="text-align:center;margin-bottom:2rem;">
        <div class="brand" style="justify-content:center;margin-bottom:1rem;">
          <div class="brand-icon" style="width:52px;height:52px;font-size:1.4rem;">عَ</div>
        </div>
        <h1 style="font-size:1.6rem;font-weight:900;margin-bottom:0.5rem;">انضم إلى مجتمع عَقول</h1>
        <p style="color:var(--text-muted);font-size:0.95rem;">أنشئ حسابك المجاني وشارك في نشر المعرفة بالعربية</p>
      </div>

      <div class="enhancer-card">
        <label class="enhancer-label">اسم المستخدم</label>
        <input type="text" id="regUsername" class="form-input" placeholder="اختر اسماً مميزاً" style="margin-bottom:16px;">

        <label class="enhancer-label">البريد الإلكتروني</label>
        <input type="email" id="regEmail" class="form-input" placeholder="you@example.com" dir="ltr" style="margin-bottom:16px;">

        <label class="enhancer-label">كلمة المرور</label>
        <input type="password" id="regPassword" class="form-input" placeholder="6 أحرف على الأقل" style="margin-bottom:20px;">

        <button id="registerBtn" class="btn-enhance" style="border-radius:50px;">إنشاء الحساب</button>

        <div style="display:flex;align-items:center;gap:12px;margin:20px 0;">
          <div style="flex:1;height:1px;background:var(--border);"></div>
          <span style="font-size:0.82rem;color:var(--text-light);white-space:nowrap;">أو سجّل عبر</span>
          <div style="flex:1;height:1px;background:var(--border);"></div>
        </div>

        <div style="display:flex;gap:12px;">
          <button id="googleRegBtn" class="social-auth-btn" style="flex:1;">
            <svg width="18" height="18" viewBox="0 0 24 24"><path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 01-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/><path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/><path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/><path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/></svg>
            Google
          </button>
          <button id="appleRegBtn" class="social-auth-btn" style="flex:1;">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.88-3.08.4-1.09-.5-2.08-.48-3.24 0-1.44.62-2.2.44-3.06-.4C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
            Apple
          </button>
        </div>

        <div id="regError" class="hidden" style="margin-top:12px;padding:10px 14px;background:var(--rose-light);color:var(--rose);border-radius:var(--radius-sm);font-size:0.85rem;font-weight:600;"></div>
        <div id="regSuccess" class="hidden" style="margin-top:12px;padding:10px 14px;background:var(--accent-light);color:var(--accent);border-radius:var(--radius-sm);font-size:0.85rem;font-weight:600;"></div>

        <div style="text-align:center;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid var(--border);">
          <p style="font-size:0.9rem;color:var(--text-muted);">
            لديك حساب بالفعل؟
            <a href="/login" style="color:var(--accent);font-weight:700;">سجّل الدخول</a>
          </p>
        </div>

        <div style="margin-top:1.5rem;padding:16px;background:var(--surface2);border-radius:var(--radius-sm);">
          <p style="font-size:0.82rem;color:var(--text-muted);line-height:1.7;text-align:center;">
            ✨ بإنشاء حسابك يمكنك:<br>
            المشاركة في المنتدى • مشاركة محتوى • حفظ المقالات • التبرّع والحصول على شارة
          </p>
        </div>
      </div>

    </div>
  </section>

  <Footer />
</BaseLayout>

<script>
  let sb: any = null;
  async function getSupabase() {
    if (sb) return sb;
    try {
      const mod = await import('../lib/supabase');
      sb = mod.supabase;
      if (!sb.supabaseUrl || sb.supabaseUrl === '') sb = null;
      return sb;
    } catch { return null; }
  }

  document.getElementById('registerBtn')?.addEventListener('click', async () => {
    const username = (document.getElementById('regUsername') as HTMLInputElement).value.trim();
    const email = (document.getElementById('regEmail') as HTMLInputElement).value.trim();
    const password = (document.getElementById('regPassword') as HTMLInputElement).value;
    const errorEl = document.getElementById('regError') as HTMLElement;
    const successEl = document.getElementById('regSuccess') as HTMLElement;

    errorEl.classList.add('hidden');
    successEl.classList.add('hidden');

    if (!username || !email || !password) {
      errorEl.textContent = 'يرجى ملء جميع الحقول';
      errorEl.classList.remove('hidden');
      return;
    }
    if (password.length < 6) {
      errorEl.textContent = 'كلمة المرور يجب أن تكون 6 أحرف على الأقل';
      errorEl.classList.remove('hidden');
      return;
    }

    const supabase = await getSupabase();
    if (!supabase) {
      errorEl.textContent = '⚠️ التسجيل يحتاج إعداد Supabase — سيتم تفعيله بعد الاستضافة';
      errorEl.classList.remove('hidden');
      return;
    }

    try {
      const { error } = await supabase.auth.signUp({
        email,
        password,
        options: { data: { username } },
      });
      if (error) {
        errorEl.textContent = 'خطأ: ' + error.message;
        errorEl.classList.remove('hidden');
      } else {
        successEl.textContent = '✅ تم إنشاء الحساب! تحقق من بريدك الإلكتروني لتأكيد الحساب.';
        successEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = '⚠️ حدث خطأ في الاتصال';
      errorEl.classList.remove('hidden');
    }
  });

  // Social register
  async function socialRegister(provider: 'google' | 'apple') {
    const errorEl = document.getElementById('regError') as HTMLElement;
    const supabase = await getSupabase();
    if (!supabase) {
      errorEl.textContent = '⚠️ نظام التسجيل قيد الإعداد';
      errorEl.classList.remove('hidden');
      return;
    }
    try {
      const { error } = await supabase.auth.signInWithOAuth({
        provider,
        options: { redirectTo: window.location.origin + '/login' },
      });
      if (error) {
        errorEl.textContent = 'خطأ: ' + error.message;
        errorEl.classList.remove('hidden');
      }
    } catch {
      errorEl.textContent = '⚠️ حدث خطأ في الاتصال';
      errorEl.classList.remove('hidden');
    }
  }

  document.getElementById('googleRegBtn')?.addEventListener('click', () => socialRegister('google'));
  document.getElementById('appleRegBtn')?.addEventListener('click', () => socialRegister('apple'));
</script>
